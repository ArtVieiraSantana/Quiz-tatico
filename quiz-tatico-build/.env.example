# ================================================
# QuizTático - Configuração de Ambiente
# Copie este arquivo para .env e preencha os valores
# ================================================

# Caminho para o banco de dados SQLite (padrão: ./data/quiz-tatico.db)
DATABASE_PATH=./data/quiz-tatico.db

# Chave secreta para assinar cookies de sessão (use uma string longa e aleatória)
JWT_SECRET=sua-chave-secreta-muito-longa-e-aleatoria-aqui

# Porta do servidor (padrão: 3000)
PORT=3000

# ID do dono/admin (openId do primeiro usuário que fará login)
OWNER_OPEN_ID=

# Configurações OAuth (fornecidas pelo Manus)
VITE_APP_ID=
OAUTH_SERVER_URL=

# Ambiente
NODE_ENV=development
